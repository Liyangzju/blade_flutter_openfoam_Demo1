FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 2 -1 0 0 0 0 ];

internalField   uniform 1e-05;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 0;
    }
    AMI1
    {
        type            cyclicAMI;
    }
    AMI2
    {
        type            cyclicAMI;
    }
    outlet
    {
        type            calculated;
        value           uniform 0;
    }
    wall
    {
        type            slip;
    }
    "(blade.*)"
    {
        type            nutLowReWallFunction;
        value           uniform 0;
    }
    hub
    {
        type            nutLowReWallFunction;
        value           uniform 0;
    }
}


